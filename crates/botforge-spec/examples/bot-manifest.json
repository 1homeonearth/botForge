{
  "bot": {"name": "squire", "version": "1.0.0"},
  "build": {"language": "rust", "target": "wasm32-wasi", "crate_path": "crates/squire"},
  "security": {"signatures_required": true, "hash_required": true, "forbidden_permissions": []},
  "platforms": {"required": ["discord"], "optional": ["reddit"]},
  "capabilities": ["discord.message.send", "botforge.state.read"],
  "events": ["discord.message.created"],
  "intents": ["discord.message.send"],
  "setup": {
    "version": "1.0.0",
    "pages": [
      {
        "id": "general",
        "title": "General",
        "fields": [
          {"key": "setup_command", "field_type": "slash_command", "required": true, "secret": false, "options": []},
          {"key": "default_channel", "field_type": "channel_select", "required": true, "secret": false, "options": []}
        ],
        "preview": {"title": "Preview", "body": "Example card"},
        "confirm_required": true
      }
    ]
  }
}
