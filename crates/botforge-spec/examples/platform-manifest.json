{
  "platform": {"name": "discord", "version": "1.0.0"},
  "build": {"language": "rust", "target": "wasm32-wasi", "crate_path": "crates/platform-discord"},
  "security": {"signatures_required": true, "hash_required": true, "forbidden_permissions": []},
  "allowed_secrets": ["bot_token"],
  "provided_capabilities": ["discord.message.send"],
  "emitted_events": ["discord.message.created"],
  "executed_intents": ["discord.message.send"],
  "setup": {"fields": [{"key": "application_id", "field_type": "string", "required": true}]}
}
